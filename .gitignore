# ══════════════════════════════════════════
# OpenClaude — .gitignore
# Framework files are tracked.
# Personal data, secrets, and runtime output are NOT.
# ══════════════════════════════════════════

# ── Secrets & credentials ─────────────────
.env

# EN folder names (new standard)
workspace/daily-logs/*
!workspace/daily-logs/.gitkeep
workspace/projects/*
!workspace/projects/.gitkeep
workspace/community/*
!workspace/community/.gitkeep
workspace/social/*
!workspace/social/.gitkeep
workspace/finance/*
!workspace/finance/.gitkeep
workspace/personal/*
!workspace/personal/.gitkeep
workspace/meetings/*
!workspace/meetings/.gitkeep
workspace/courses/*
!workspace/courses/.gitkeep
workspace/strategy/*
!workspace/strategy/.gitkeep

# ── Agent memory (runtime, personal) ──────
.claude/agent-memory/
memory/

# ── Product-specific skills (not generic) ─
.claude/skills/int-licensing/
.claude/skills/int-whatsapp/
.claude/skills/prod-licensing-daily/
.claude/skills/prod-licensing-weekly/
.claude/skills/prod-licensing-monthly/

# ── Custom templates (user-specific) ─────
.claude/templates/html/custom/

# ── Custom routines (user-specific, all in one place) ─
ADWs/routines/custom/

# ── Runtime data & logs ───────────────────
ADWs/logs/
dashboard/data/*.db
dashboard/data/*.db-shm
dashboard/data/*.db-wal
dashboard/data/.secret_key
dashboard/frontend/node_modules/
dashboard/frontend/dist/

# ── Evo Method (separate project) ────────
_evo/
_evo-output/
.claude/skills/evo-*/

# ── Python ────────────────────────────────
.venv/
__pycache__/
*.pyc

# ── OS ────────────────────────────────────
.DS_Store
Thumbs.db

# ── Generated configs (user-specific) ────
CLAUDE.md
config/workspace.yaml
config/routines.yaml

# ── Claude Code session data ─────────────
.claude/projects/
.claude/image-cache/
.claude/todos/
.claude/TASKS.md
